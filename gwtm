#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RELEASE_BIN="$SCRIPT_DIR/target/release/gwtm"
DEBUG_BIN="$SCRIPT_DIR/target/debug/gwtm"
SOURCE_ROOT="$SCRIPT_DIR/src"
MANIFEST_PATH="$SCRIPT_DIR/Cargo.toml"
LOCK_PATH="$SCRIPT_DIR/Cargo.lock"

has_newer_sources() {
  local bin_path="$1"

  if [[ ! -e "$bin_path" ]]; then
    return 0
  fi

  if [[ -d "$SOURCE_ROOT" ]] && find "$SOURCE_ROOT" -type f -newer "$bin_path" -print -quit | grep -q .; then
    return 0
  fi

  if [[ -f "$MANIFEST_PATH" && "$MANIFEST_PATH" -nt "$bin_path" ]]; then
    return 0
  fi

  if [[ -f "$LOCK_PATH" && "$LOCK_PATH" -nt "$bin_path" ]]; then
    return 0
  fi

  return 1
}

run_built_binary() {
  local bin_path="$1"
  shift
  if [[ -x "$bin_path" ]] && ! has_newer_sources "$bin_path"; then
    exec "$bin_path" "$@"
  fi
}

if [[ "${USE_BUILT_BIN:-0}" == "1" ]]; then
  if [[ -x "$RELEASE_BIN" ]]; then
    exec "$RELEASE_BIN" "$@"
  fi
  if [[ -x "$DEBUG_BIN" ]]; then
    exec "$DEBUG_BIN" "$@"
  fi
fi

run_built_binary "$RELEASE_BIN" "$@"
run_built_binary "$DEBUG_BIN" "$@"

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo not found in PATH. Install the Rust toolchain or set USE_BUILT_BIN=1." >&2
  exit 1
fi

exec cargo run --quiet --manifest-path "$MANIFEST_PATH" -- "$@"
